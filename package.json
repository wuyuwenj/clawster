{
  "name": "clawster",
  "version": "0.1.5",
  "author": "Yuwen Wu",
  "description": "Web-based AI sales mascot for clothing brands",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "vite --config vite.web.config.ts",
    "dev:api": "node server/index.js",
    "build": "node scripts/clean-dist.mjs && npm run build:web && npm run build:widget",
    "build:web": "vite build --config vite.web.config.ts",
    "build:widget": "vite build --config vite.widget.config.ts",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@iconify/react": "^6.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "openai": "^4.104.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.24",
    "postcss": "^8.5.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.3.0",
    "vite": "^8.0.1"
  }
}
