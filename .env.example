# Development server port (default: 5173)
VITE_DEV_PORT=5173

# OpenAI API key (optional, no longer required for screenshot analysis)
# OPENAI_API_KEY=your-openai-api-key-here

# Ollama server URL (dev convenience, CLA-62). Unset = localhost default
# (http://127.0.0.1:11434). Point at a remote/self-hosted Ollama — a Mac Mini
# over LAN or a Cloudflare Tunnel — to offload the local tool model.
# CLAWSTER_OLLAMA_URL=http://192.168.1.50:11434
