      "build:renderer": "vite build",
      "dist": "npm run build && electron-builder",
      "dist:mac": "npm run build && electron-builder --mac",
      "dist:mac:deploy": "npm run dist:mac && rm -f ../clawster-landign-electronbuilder/public/downloads/Clawster-*mac* ../clawster-landign-electronbuilder/public/downloads/latest-mac.yml && cp release/Clawster-*-arm64.dmg release/Clawster-*-arm64-mac.zip release/Clawster-*-arm64-mac.zip.blockmap release/latest-mac.yml ../clawster-landign-electronbuilder/public/downloads/",
